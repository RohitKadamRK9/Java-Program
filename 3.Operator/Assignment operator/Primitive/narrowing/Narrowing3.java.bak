class Narrowing3
{
	public static void main(String []args)
	{
		long a = 2200000000;
		int i1 = (int)a;
		char c1 = (char)a;
		short s1 = (short)a;
		byte b1 = (byte)a ;
		
		System.out.println(a);
		System.out.println(i1);
		System.out.println(c1);
		System.out.println(s1);
		System.out.println(b1);
		
	}
}