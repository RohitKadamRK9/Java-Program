class Square1
{
	public static void main()
	{
		int n = 17 ;
		for(int i = 0 ; i<n ; i++)
		{
			for(int j = 0 ; j<n ; j++)
			{
				if(i==0||j==0|| j == n-1 ||i==n-1||i==n/2||i==n+7/8&&j==n+7/8)
				{	
				System.out.print("*"+" ");
				}
				else
				{
					System.out.print("  ");
				}
			}
			System.out.println();
		}
	}
}